import streamlit as st
import os

st.set_page_config(page_title="Guilherme Oyakawa - Credentials", layout="wide")

st.title("📜 Professional Certifications & Academic Records")
st.write("A comprehensive view of my technical expertise and academic background.")

# Dicionário de certificados com caminhos e descrições
certificates = [
    {"title": "Master in Data Science", "file": "certificates/Certificate - GUILHERME OYAKAWA DE ALMEIDA.jpg", "issuer": "Rome Business School"},
    {"title": "Power BI Data Analyst", "file": "certificates/DataCampCertification_PBI.jpg", "issuer": "DataCamp"},
    {"title": "SQL Data Analyst", "file": "certificates/DataCampCertification_SQL.jpg", "issuer": "DataCamp"},
    {"title": "Python Data Analyst", "file": "certificates/certificate_python Data Analyst.jpg", "issuer": "DataCamp"},
    {"title": "Academic Transcript", "file": "certificates/Transcript - Guilherme Oyakawa De Almeida.jpg", "issuer": "Rome Business School"},
]

# Criando colunas para a galeria (3 por linha)
cols = st.columns(3)

for i, cert in enumerate(certificates):
    with cols[i % 3]:
        st.subheader(cert["title"])
        st.caption(f"Issued by: {cert['issuer']}")
        if os.path.exists(cert["file"]):
            st.image(cert["file"], use_container_width=True)
            with open(cert["file"], "rb") as file:
                st.download_button(
                    label=f"Download {cert['title']}",
                    data=file,
                    file_name=cert["file"].split('/')[-1],
                    mime="image/jpeg"
                )
        else:
            st.error(f"Image for {cert['title']} not found.")
        st.divider()
